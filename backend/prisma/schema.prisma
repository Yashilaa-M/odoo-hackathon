datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RoleName {
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleType {
  TRUCK
  VAN
  BIKE
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  ACTIVE
  CLOSED
}

enum ExpenseCategory {
  TOLL
  MAINTENANCE
  FUEL
  OTHER
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  roleId       String   @map("role_id") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  role            Role             @relation(fields: [roleId], references: [id])
  drivers         Driver?
  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]
  auditLogs       AuditLog[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        RoleName @unique
  permissions Json?
  users       User[]

  @@map("roles")
}

model Vehicle {
  id                 String        @id @default(uuid()) @db.Uuid
  registrationNumber String        @unique @map("registration_number")
  nameModel          String        @map("name_model")
  type               VehicleType
  maxLoadCapacityKg  Decimal       @db.Decimal(10, 2) @map("max_load_capacity_kg")
  odometerKm         Decimal       @default(0) @db.Decimal(10, 2) @map("odometer_km")
  acquisitionCost    Decimal       @db.Decimal(12, 2) @map("acquisition_cost")
  region             String?
  status             VehicleStatus @default(AVAILABLE)
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]

  @@index([status])
  @@index([type])
  @@index([region])
  @@map("vehicles")
}

model Driver {
  id                 String       @id @default(uuid()) @db.Uuid
  userId             String?      @unique @map("user_id") @db.Uuid
  fullName           String       @map("full_name")
  licenseNumber      String       @unique @map("license_number")
  licenseCategory    String       @map("license_category")
  licenseExpiryDate  DateTime     @db.Date @map("license_expiry_date")
  contactNumber      String       @map("contact_number")
  safetyScore        Decimal      @default(100) @db.Decimal(5, 2) @map("safety_score")
  status             DriverStatus @default(AVAILABLE)
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  user  User?  @relation(fields: [userId], references: [id])
  trips Trip[]

  @@index([status])
  @@index([licenseExpiryDate])
  @@map("drivers")
}

model Trip {
  id                String     @id @default(uuid()) @db.Uuid
  source            String
  destination       String
  vehicleId         String     @map("vehicle_id") @db.Uuid
  driverId          String     @map("driver_id") @db.Uuid
  cargoWeightKg     Decimal    @db.Decimal(10, 2) @map("cargo_weight_kg")
  plannedDistanceKm Decimal    @db.Decimal(10, 2) @map("planned_distance_km")
  actualDistanceKm  Decimal?   @db.Decimal(10, 2) @map("actual_distance_km")
  fuelConsumedL     Decimal?   @db.Decimal(10, 2) @map("fuel_consumed_l")
  revenue           Decimal    @default(0) @db.Decimal(12, 2)
  status            TripStatus @default(DRAFT)
  createdBy         String?    @map("created_by") @db.Uuid
  dispatchedAt      DateTime?  @map("dispatched_at")
  completedAt       DateTime?  @map("completed_at")
  cancelledAt       DateTime?  @map("cancelled_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id])
  driver    Driver    @relation(fields: [driverId], references: [id])
  creator   User?     @relation(fields: [createdBy], references: [id])
  fuelLogs  FuelLog[]
  expenses  Expense[]

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
  @@map("trips")
}

model MaintenanceLog {
  id          String            @id @default(uuid()) @db.Uuid
  vehicleId   String            @map("vehicle_id") @db.Uuid
  type        String
  description String?
  cost        Decimal           @db.Decimal(12, 2)
  status      MaintenanceStatus @default(ACTIVE)
  openedAt    DateTime          @default(now()) @map("opened_at")
  closedAt    DateTime?         @map("closed_at")
  createdBy   String?           @map("created_by") @db.Uuid

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  creator User?   @relation(fields: [createdBy], references: [id])

  @@index([vehicleId])
  @@index([status])
  @@map("maintenance_logs")
}

model FuelLog {
  id         String   @id @default(uuid()) @db.Uuid
  vehicleId  String   @map("vehicle_id") @db.Uuid
  tripId     String?  @map("trip_id") @db.Uuid
  liters     Decimal  @db.Decimal(10, 2)
  cost       Decimal  @db.Decimal(10, 2)
  loggedDate DateTime @db.Date @map("logged_date")
  createdBy  String?  @map("created_by") @db.Uuid

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  trip    Trip?   @relation(fields: [tripId], references: [id])
  creator User?   @relation(fields: [createdBy], references: [id])

  @@index([vehicleId])
  @@index([loggedDate])
  @@map("fuel_logs")
}

model Expense {
  id           String          @id @default(uuid()) @db.Uuid
  vehicleId    String          @map("vehicle_id") @db.Uuid
  tripId       String?         @map("trip_id") @db.Uuid
  category     ExpenseCategory
  amount       Decimal         @db.Decimal(12, 2)
  description  String?
  incurredDate DateTime        @db.Date @map("incurred_date")
  createdBy    String?         @map("created_by") @db.Uuid

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  trip    Trip?   @relation(fields: [tripId], references: [id])
  creator User?   @relation(fields: [createdBy], references: [id])

  @@index([vehicleId])
  @@index([category])
  @@index([incurredDate])
  @@map("expenses")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id") @db.Uuid
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id])

  @@map("audit_logs")
}
